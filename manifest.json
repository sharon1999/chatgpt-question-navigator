{
  "manifest_version": 3,
  "name": "ChatGPT Question Navigator",
  "version": "1.0",
  "description": "Navigate your long ChatGPT conversations by viewing all the questions you asked.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Show questions"
  },
  "content_scripts": [
    {
      "matches": ["*://chatgpt.com/*", "*://*.chatgpt.com/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://chatgpt.com/*", "*://*.chatgpt.com/*"]
}
