{
  "manifest_version": 3,
  "name": "AI Question Navigator",
  "version": "1.1",
  "description": "Navigate your long AI conversations by viewing all the prompts you asked.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Show questions",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*", 
        "*://*.chatgpt.com/*",
        "*://claude.ai/*",
        "*://*.claude.ai/*",
        "*://gemini.google.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "*://chatgpt.com/*", 
    "*://*.chatgpt.com/*",
    "*://claude.ai/*",
    "*://*.claude.ai/*",
    "*://gemini.google.com/*"
  ]
}
